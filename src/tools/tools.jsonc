    "type": "function",
    "function": {
      "name": "mcp_sampling_create_message",
      "description": "调用 MCP sampling/createMessage 能力。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "sampling_params": {
            "type": "object"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server", "sampling_params"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_completion_complete",
      "description": "调用 MCP completion/complete 能力。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "completion_params": {
            "type": "object"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server", "completion_params"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_status",
      "description": "仅从内存缓存读取 MCP 状态。",
      "parameters": {
        "type": "object",
        "properties": {
          "log_limit": {
            "type": "integer"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_status_refresh",
      "description": "通过实时服务器检查刷新 MCP 状态。",
      "parameters": {
        "type": "object",
        "properties": {
          "servers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timeout_s": {
            "type": "number"
          },
          "force": {
            "type": "boolean"
          },
          "log_limit": {
            "type": "integer"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_reconnect",
      "description": "重连单个 MCP 服务器并刷新其工具列表。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_search",
      "description": "在当前工作区作用域内语义检索「经验记忆」。缺信息以完成任务时，须先于其它内置工具 / skills / MCP 调用本工具（可明确判定与历史记忆无关的单次输入或纯外部事实除外）；若无命中或仍不足，再用其它能力补齐。若本轮 system 中【经验记忆】已完整覆盖所需信息则不必重复检索。自然语言指称实体且缺少稳定标识时，用实体名/别名 + 可能的关键词作 query，禁止未检索就臆造编号。query 填检索要点；可选 limit。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_add",
      "description": "写入一条经验记忆。仅用于事实性的简短条目（约定、偏好结论、纠正结果）。若用户强调「永远/长期/一直记住」且内容是稳定默认（称呼、助手显示名、长期交互规则），应改用 user_preferences_patch，勿仅用本工具代替。禁止保存代码片段、脚本/命令原始输出、日志原文或总结后的大段文本；代码/输出信息应通过 shell（必要时配合 summarize）实时读取。禁止写入密码、token、私钥。若你认为用户观点可能有误，可在 system_note 中写明你的独立判断。",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "tier": {
            "type": "string",
            "description": "working | episodic | durable"
          },
          "memory_type": {
            "type": "string",
            "description": "如 lesson / preference / note"
          },
          "source": {
            "type": "string",
            "description": "如 assistant / user_request / auto"
          },
          "user_request": {
            "type": "string"
          },
          "system_note": {
            "type": "string"
          }
        },
        "required": ["content"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_list",
      "description": "列出当前工作区作用域下最近的经验记忆摘要（按最近访问排序）。",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_stats",
      "description": "读取经验记忆存储统计（条数、嵌入模型、目录）。",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_delete",
      "description": "按 id 删除一条经验记忆。",
      "parameters": {
        "type": "object",
        "properties": {
          "memory_id": {
            "type": "string"
          }
        },
        "required": ["memory_id"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "user_preferences_read",
      "description": "读取持久化用户偏好文件全文（config 目录下 user_preferences.md），用于修改前查看当前内容。非经验记忆库；该文件内容会固定注入 system。可选 max_chars 截断返回。",
      "parameters": {
        "type": "object",
        "properties": {
          "max_chars": {
            "type": "integer",
            "description": "可选，正文最大字符数，默认 16000"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "user_preferences_patch",
      "description": "写入/更新持久化用户偏好文件（Markdown + YAML 头）。每轮对话会自动注入 system。用户说「永远记住」「以后一直」「别忘」且指稳定口径（尤其助手/用户称呼、默认语气与规则）时必须使用本工具（通常 upsert_section），而非仅 memory_add。operation=replace_body 替换正文；operation=upsert_section 按二级标题插入或替换小节。禁止写入密钥/token。",
      "parameters": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "description": "replace_body | upsert_section"
          },
          "markdown_body": {
            "type": "string",
            "description": "replace_body 时必填：完整 Markdown 正文（不含 YAML 头）"
          },
          "section_heading": {
            "type": "string",
            "description": "upsert_section 时必填：小节标题（不要写 ##）"
          },
          "section_body": {
            "type": "string",
            "description": "upsert_section 时：小节正文 Markdown"
          }
        },
        "required": ["operation"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "freedom_on",
      "description": "开启自由模式确认策略。",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "freedom_off",
      "description": "关闭自由模式确认策略。",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "always_confirm_reset",
      "description": "清空免确认白名单并强制重新确认。",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "request_skill_prompt",
      "description": "请求注入指定 skill 的提示（虚拟控制工具，不直接执行业务操作）。支持长技能正文分段注入：可传 section 加载指定段，或 full=true 加载完整正文。",
      "parameters": {
        "type": "object",
        "properties": {
          "skill_id": {
            "type": "string"
          },
          "section": {
            "type": "integer",
            "minimum": 1
          },
          "full": {
            "type": "boolean"
          }
        },
        "required": ["skill_id"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "ask_more_info",
      "description": "当缺少关键输入时，向用户请求补充信息并暂停自动续步，待用户输入后继续。须已先按顺序尝试 memory_search 与其它工具/skills/MCP 仍无法可靠获得时再调用。",
      "parameters": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "expected_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["question"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "task_changed",
      "description": "当用户补充信息与原始需求完全无关时，声明切换到新任务。",
      "parameters": {
        "type": "object",
        "properties": {
          "new_task": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "required": ["new_task"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "done",
      "description": "标记当前用户任务已完成。若本轮修改了文件，args.reviewed_files 应列出已复查文件清单。",
      "parameters": {
        "type": "object",
        "properties": {
          "reviewed_files": {
            "type": "array",
            "description": "可选。已复查文件路径列表。software_development 场景下若有代码改动，需覆盖本轮所有已修改文件。",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
]
