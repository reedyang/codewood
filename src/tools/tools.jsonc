// Tool specs loaded at runtime (JSONC supported).
[
  {
    "type": "function",
    "function": {
      "name": "shell",
      "description": "在当前工作目录执行系统 shell 命令。",
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string"
          },
          "force": {
            "type": "boolean"
          }
        },
        "required": ["command"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "apply_patch",
      "description": "对指定文本文件应用标准 unified diff（patch/git apply 格式，包含 ---/+++ 与 @@ hunk）。",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "patch": {
            "type": "string",
            "description": "优先使用标准 patch/git apply unified diff（含 ---/+++ 与至少一个 @@ ... @@ hunk）。"
          }
        },
        "required": ["path", "patch"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "read_image",
      "description": "读取图片文件并返回 AI 对图片内容的理解结果。",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          }
        },
        "required": ["path"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "project_context_search",
      "description": "面向大项目的轻量代码上下文检索：按 query 返回候选文件、相关符号与匹配原因。支持增量索引刷新、强制重建与状态查看。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "检索意图，例如“where auth token validated”或“RoomSettingsPanel timer crash”"
          },
          "max_files": {
            "type": "integer",
            "description": "最多返回候选文件数（默认 12，最大 50）"
          },
          "refresh": {
            "type": "boolean",
            "description": "是否在检索前做一次增量刷新（默认 true）"
          },
          "refresh_async": {
            "type": "boolean",
            "description": "是否异步触发增量刷新（默认 false）；启用后本次先用当前索引返回候选，刷新结果在后续轮次生效"
          },
          "force_rebuild": {
            "type": "boolean",
            "description": "是否强制全量重建索引后再检索（慢）"
          },
          "status_only": {
            "type": "boolean",
            "description": "仅返回索引状态，不执行检索"
          }
        },
        "required": ["query"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_server_info",
      "description": "查询指定 MCP 服务器的聚合信息（状态、tools/resources/prompts）。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "refresh": {
            "type": "boolean"
          },
          "timeout_s": {
            "type": "number"
          },
          "include_tools": {
            "type": "boolean"
          },
          "include_resources": {
            "type": "boolean"
          },
          "include_resource_templates": {
            "type": "boolean"
          },
          "include_prompts": {
            "type": "boolean"
          }
        },
        "required": ["server"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_reload_config",
      "description": "手动重载 mcp.json 配置并按增量规则热更新 MCP（新增/变更/删除）。",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_disable_tools",
      "description": "禁用指定 MCP server 的 tools（支持逗号分隔字符串或数组）。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tools": {
            "description": "tool 名称列表，支持 \"a,b,c\" 或 [\"a\",\"b\"]",
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "required": ["server", "tools"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_enable_tools",
      "description": "启用（解除禁用）指定 MCP server 的 tools（支持逗号分隔字符串或数组）。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tools": {
            "description": "tool 名称列表，支持 \"a,b,c\" 或 [\"a\",\"b\"]",
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "required": ["server", "tools"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_list_disabled_tools",
      "description": "查看 MCP tool 禁用清单（可按 server 查询）。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_list_tools",
      "description": "列出指定 MCP 服务器可用的工具。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "use_cache": {
            "type": "boolean"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_call_tool",
      "description": "使用 JSON 参数调用单个 MCP 工具。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tool": {
            "type": "string"
          },
          "arguments": {
            "type": "object"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server", "tool"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_call_tool_batch",
      "description": "在一次批处理请求中调用多个 MCP 工具。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "calls": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "timeout_s": {
            "type": "number"
          },
          "allow_partial_failure": {
            "type": "boolean"
          }
        },
        "required": ["server", "calls"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_list_resources",
      "description": "列出指定 MCP 服务器的资源。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "use_cache": {
            "type": "boolean"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server"]
