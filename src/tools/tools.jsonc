        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server", "uri"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_list_resource_templates",
