// Tool specs loaded at runtime (JSONC supported).
[
  {
    "type": "function",
    "function": {
      "name": "shell",
      "description": "Execute a system shell command in the current working directory.",
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string"
          },
          "force": {
            "type": "boolean"
          }
        },
        "required": ["command"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "apply_patch",
      "description": "Apply a standard unified diff to a specified text file (patch/git apply format, including ---/+++ and @@ hunks).",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "patch": {
            "type": "string",
            "description": "Prefer a standard patch/git apply unified diff, including ---/+++ and at least one @@ ... @@ hunk."
          }
        },
        "required": ["path", "patch"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "read_image",
      "description": "Read an image file and return the AI interpretation of its contents.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          }
        },
        "required": ["path"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "project_context_search",
      "description": "Lightweight code-context retrieval for large projects: returns candidate files, related symbols, and match reasons by query. Supports incremental index refresh, forced rebuild, and status checks.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Retrieval intent, for example 'where auth token validated' or 'RoomSettingsPanel timer crash'."
          },
          "max_files": {
            "type": "integer",
            "description": "Maximum number of candidate files to return (default 12, max 50)."
          },
          "refresh": {
            "type": "boolean",
            "description": "Whether to run an incremental refresh before retrieval (default true)."
          },
          "refresh_async": {
            "type": "boolean",
            "description": "Whether to trigger incremental refresh asynchronously (default false). If enabled, this call returns candidates from the current index first; refresh results affect later turns."
          },
          "force_rebuild": {
            "type": "boolean",
            "description": "Whether to force a full index rebuild before retrieval (slow)."
          },
          "status_only": {
            "type": "boolean",
            "description": "Return only index status; do not run retrieval."
          }
        },
        "required": ["query"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_server_info",
      "description": "Query aggregated information for a specified MCP server (status, tools, resources, prompts).",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "refresh": {
            "type": "boolean"
          },
          "timeout_s": {
            "type": "number"
          },
          "include_tools": {
            "type": "boolean"
          },
          "include_resources": {
            "type": "boolean"
          },
          "include_resource_templates": {
            "type": "boolean"
          },
          "include_prompts": {
            "type": "boolean"
          }
        },
        "required": ["server"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_reload_config",
      "description": "Manually reload mcp.jsonc and hot-update MCP incrementally (add/change/delete).",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_disable_tools",
      "description": "Disable tools for a specified MCP server (supports comma-separated string or array).",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tools": {
            "description": "List of tool names; supports \"a,b,c\" or [\"a\",\"b\"].",
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "required": ["server", "tools"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_enable_tools",
      "description": "Enable (undelete from disabled list) tools for a specified MCP server (supports comma-separated string or array).",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tools": {
            "description": "List of tool names; supports \"a,b,c\" or [\"a\",\"b\"].",
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "required": ["server", "tools"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_list_disabled_tools",
      "description": "View the MCP tool disabled list (optionally filtered by server).",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_list_tools",
      "description": "List available tools for a specified MCP server.",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "use_cache": {
            "type": "boolean"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_call_tool",
      "description": "Call a single MCP tool with JSON arguments.",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tool": {
            "type": "string"
          },
          "arguments": {
            "type": "object"
          },
          "timeout_s": {
            "type": "number"
          }
        },
        "required": ["server", "tool"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_call_tool_batch",
      "description": "Call multiple MCP tools in one batch request.",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "calls": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "timeout_s": {
            "type": "number"
          },
          "allow_partial_failure": {
            "type": "boolean"
          }
        },
        "required": ["server", "calls"]
      }
    }
  },
  {
    "type": "function",
    "function": {
