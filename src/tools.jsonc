    }
  },
  {
    "type": "function",
    "function": {
      "name": "knowledge_search",
      "description": "在本地知识库中语义检索（仅当用户本轮明确需要）。禁止：用户未明确要求检索知识库、参考知识库/本地文档库信息时，不得调用。必须：用户明确要求「检索知识库」「在知识库里查」「参考知识库中的资料」或清晰等价表述时，必须先调用本工具取得相关片段，再回答或继续其他步骤；禁止在未调用本工具的情况下声称已依据知识库。query 填检索主题或用户关心的要点；可选 limit 限制条数。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_search",
      "description": "在当前工作区作用域内语义检索「经验记忆」（不是知识库）。缺信息以完成任务时，须先于其它内置工具 / skills / MCP 调用本工具（可明确判定与历史记忆无关的单次输入或纯外部事实除外）；若无命中或仍不足，再用其它能力补齐。若本轮 system 中【经验记忆】已完整覆盖所需信息则不必重复检索。自然语言指称实体且缺少稳定标识时，用实体名/别名 + 可能的关键词作 query，禁止未检索就臆造编号。query 填检索要点；可选 limit。",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_add",
      "description": "写入一条经验记忆（非知识库文档）。仅用于事实性的简短条目（约定、偏好结论、纠正结果）。若用户强调「永远/长期/一直记住」且内容是稳定默认（称呼、助手显示名、长期交互规则），应改用 user_preferences_patch，勿仅用本工具代替。禁止保存代码片段、脚本/命令原始输出、日志原文或总结后的大段文本；代码/输出信息应通过 read/grep/summarize/shell 实时读取。禁止写入密码、token、私钥。若你认为用户观点可能有误，可在 system_note 中写明你的独立判断。",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "tier": {
            "type": "string",
            "description": "working | episodic | durable"
          },
          "memory_type": {
            "type": "string",
            "description": "如 lesson / preference / note"
          },
          "source": {
            "type": "string",
            "description": "如 assistant / user_request / auto"
          },
          "user_request": {
            "type": "string"
          },
          "system_note": {
            "type": "string"
          }
        },
        "required": ["content"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_list",
      "description": "列出当前工作区作用域下最近的经验记忆摘要（按最近访问排序）。",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_stats",
      "description": "读取经验记忆存储统计（条数、嵌入模型、目录）。",
      "parameters": {
        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "memory_delete",
      "description": "按 id 删除一条经验记忆。",
      "parameters": {
        "type": "object",
        "properties": {
          "memory_id": {
            "type": "string"
          }
        },
        "required": ["memory_id"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "user_preferences_read",
      "description": "读取持久化用户偏好文件全文（config 目录下 user_preferences.md），用于修改前查看当前内容。非经验记忆库；该文件内容会固定注入 system。可选 max_chars 截断返回。",
      "parameters": {
        "type": "object",
        "properties": {
          "max_chars": {
            "type": "integer",
            "description": "可选，正文最大字符数，默认 16000"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "user_preferences_patch",
      "description": "写入/更新持久化用户偏好文件（Markdown + YAML 头）。每轮对话会自动注入 system。用户说「永远记住」「以后一直」「别忘」且指稳定口径（尤其助手/用户称呼、默认语气与规则）时必须使用本工具（通常 upsert_section），而非仅 memory_add。operation=replace_body 替换正文；operation=upsert_section 按二级标题插入或替换小节。禁止写入密钥/token。",
      "parameters": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "description": "replace_body | upsert_section"
          },
          "markdown_body": {
            "type": "string",
            "description": "replace_body 时必填：完整 Markdown 正文（不含 YAML 头）"
          },
          "section_heading": {
            "type": "string",
            "description": "upsert_section 时必填：小节标题（不要写 ##）"
          },
          "section_body": {
            "type": "string",
            "description": "upsert_section 时：小节正文 Markdown"
          }
        },
        "required": ["operation"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "freedom_on",
