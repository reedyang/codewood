        "type": "object",
        "properties": {}
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "mcp_disable_tools",
      "description": "禁用指定 MCP server 的 tools（支持逗号分隔字符串或数组）。",
      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tools": {
            "description": "tool 名称列表，支持 \"a,b,c\" 或 [\"a\",\"b\"]",
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "required": ["server", "tools"]
      }
    }
  },
  {
    "type": "function",
    "function": {
