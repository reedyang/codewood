      "parameters": {
        "type": "object",
        "properties": {
          "server": {
            "type": "string"
          },
          "tools": {
            "description": "tool 名称列表，支持 \"a,b,c\" 或 [\"a\",\"b\"]",
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "required": ["server", "tools"]
      }
