// Tool specs loaded at runtime (JSONC supported).
[
  {
    "type": "function",
    "function": {
      "name": "list",
      "description": "列出目录条目，支持基础过滤与智能过滤。",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "路径或名称；若非绝对路径则相对当前工作目录"
          },
          "filter": {
            "type": "string",
            "description": "简单名称/扩展名过滤"
          },
          "smart_filter": {
            "type": "string",
            "description": "用于大小/时间/复合条件的自然语言过滤"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "cd",
      "description": "校验后切换当前工作目录。",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        }
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "rename",
      "description": "重命名当前工作区中的文件或目录。",
